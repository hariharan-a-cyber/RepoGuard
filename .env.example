# Gemini settings (required for AI guidance on findings)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional OpenAI-compatible fallback (used if GEMINI_API_KEY is unset)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=45

# Scanner hardening settings
SEMGREP_TIMEOUT_SECONDS=300
BANDIT_TIMEOUT_SECONDS=180
MAX_FINDINGS=200

# Comma-separated allowed frontend origins for API CORS
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Google One Tap / OAuth Web Client ID
GOOGLE_CLIENT_ID=

# Signed auth token settings
# Generate a 64-character random secret and keep it out of git history.
TOKEN_SECRET=CHANGE_ME_use_a_64_char_random_string
TOKEN_ACCESS_TTL_SECONDS=900
TOKEN_REFRESH_TTL_SECONDS=2592000
# Legacy fallback for access token TTL (optional)
TOKEN_TTL_SECONDS=900

# Enable/disable lifetime plan override feature (keep false in production)
ENABLE_LIFETIME_PRO_OVERRIDE=false

# Comma-separated emails that should always have Pro plan (testing only)
LIFETIME_PRO_EMAILS=

# Comma-separated emails allowed to view feedback admin reports
FEEDBACK_ADMIN_EMAILS=your-admin@yourdomain.com

GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
REDIS_URL=
AUTH_RATE_LIMIT_KEY_PREFIX=repoguard:auth:ratelimit
REFRESH_TOKEN_COOKIE_NAME=repoguard_refresh_token
